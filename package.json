{
  "name": "docuflow-ai",
  "version": "0.0.0",
  "private": true,
  "description": "DocuFlow AI - Serverless intelligent invoice and receipt processing platform on AWS",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "lint": "pnpm -r --parallel run lint",
    "typecheck": "pnpm -r --parallel run typecheck",
    "test": "pnpm -r --parallel run test",
    "build": "pnpm -r --parallel run build",
    "sam:validate": "sam validate --lint --template infrastructure/template.yaml"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1079.0",
    "@aws-sdk/client-s3": "^3.1079.0",
    "@aws-sdk/client-secrets-manager": "^3.1079.0",
    "@aws-sdk/client-sfn": "^3.1079.0",
    "@aws-sdk/client-textract": "^3.1079.0",
    "@aws-sdk/lib-dynamodb": "^3.1079.0",
    "@aws-sdk/s3-request-presigner": "^3.1079.0"
  }
}
